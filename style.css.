* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}


:root {
  --primary: #e94560;
  --bg-dark: #1a1a2e;
  --bg-card: #16213e;
  --text-main: #ffffff;
  --text-gray: #bbb;
}


body {
  font-family: 'Segoe UI', sans-serif;
  background-color: var(--bg-dark);
  color: var(--text-main);
  line-height: 1.6;
}


.header {
  background: var(--bg-dark);
  padding: 1.2rem 2rem;
  border-bottom: 3px solid var(--primary);
}

.nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.nav-links {
  display: flex;
  list-style: none;
  gap: 20px;
}

.nav-links a {
  color: var(--text-main);
  text-decoration: none;
  transition: 0.3s;
}

.nav-links a:hover {
  color: var(--primary);
}


.stats-grid {
  display: grid;
  /* Crea 4 columnas iguales (o menos en pantallas chicas) */
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 20px;
  padding: 20px;
}

.stat-card {
  background: var(--bg-card);
  border: 1px solid var(--primary);
  padding: 20px;
  text-align: center;
  border-radius: 8px;
}

.stat-value {
  font-size: 2rem;
  font-weight: bold;
  color: var(--primary);
}


form {
  display: flex;
  flex-direction: column;
  max-width: 400px;
  margin: 20px auto;
  gap: 10px;
}

input, select {
  padding: 10px;
  background: var(--bg-card);
  border: 1px solid var(--primary);
  color: white;
  border-radius: 4px;
}

.btn {
  background: var(--primary);
  color: white;
  padding: 12px;
  border: none;
  border-radius: 4px;
  cursor: pointer;
  font-weight: bold;
}
